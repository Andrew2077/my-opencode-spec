+function loadCliProxyApiFromOpenCodeConfig(): void {
+  if (process.env.CLIPROXYAPI_API_KEY && process.env.CLIPROXYAPI_BASE_URL) return;
+
+  const home = process.env.USERPROFILE || process.env.HOME;
+  if (!home) return;
+
+  const configPath = path.join(home, '.opencode', 'opencode.json');
+  if (!existsSync(configPath)) return;
+
+  try {
+    const parsed = JSON.parse(readFileSync(configPath, 'utf8')) as {
+      provider?: {
+        cliproxyapi?: {
+          options?: {
+            apiKey?: string;
+            baseURL?: string;
+          };
+        };
+      };
+    };
+    const options = parsed.provider?.cliproxyapi?.options;
+    if (!process.env.CLIPROXYAPI_API_KEY && options?.apiKey) {
+      process.env.CLIPROXYAPI_API_KEY = options.apiKey;
+    }
+    if (!process.env.CLIPROXYAPI_BASE_URL && options?.baseURL) {
+      process.env.CLIPROXYAPI_BASE_URL = options.baseURL;
+    }
+  } catch {
+    // Ignore missing or malformed optional OpenCode config.
+  }
+}
+
+loadCliProxyApiFromOpenCodeConfig();
+
