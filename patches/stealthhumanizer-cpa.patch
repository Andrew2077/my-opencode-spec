+  return maybeProcess?.env?.[name];
+}
+
+function getCliProxyApiChatCompletionsUrl(): string {
+  const configured = getRuntimeEnv('CLIPROXYAPI_CHAT_COMPLETIONS_URL') || getRuntimeEnv('CLIPROXYAPI_BASE_URL');
