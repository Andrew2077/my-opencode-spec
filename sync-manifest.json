{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Allowlist/denylist for syncing a safe OpenCode setup into this private repo.",
  "sourceRootName": ".opencode",
  "destinationRoot": ".opencode",
  "include": [
    "AGENTS.md",
    "AGENT_ALIGNMENT.md",
    ".env.example",
    ".version",
    "package.json",
    "package-lock.json",
    "tsconfig.json",
    "tui.json",
    "opencodex-fast.jsonc",
    "dcp.jsonc",
    "agent",
    "command",
    "skill",
    "tool",
    "plugin",
    "context",
    "dcp-prompts"
  ],
  "sanitizeJson": [
    {
      "source": "opencode.json",
      "destination": "opencode.example.json",
      "redactKeys": [
        "apiKey",
        "api_key",
        "token",
        "accessToken",
        "refreshToken",
        "secret",
        "password"
      ],
      "redaction": "__SET_IN_LOCAL_ENV_OR_CONFIG__",
      "stringReplacements": [
        {
          "description": "Redact maintainer Windows username from absolute paths",
          "pattern": "[A-Z]:/Users/[^/\"\\\\]+/",
          "replacement": "__SET_IN_LOCAL_ENV_OR_CONFIG__/"
        },
        {
          "description": "Redact maintainer Windows username from backslash paths",
          "pattern": "[A-Z]:\\\\\\\\Users\\\\\\\\[^\\\\\\\\\"]+\\\\\\\\",
          "replacement": "__SET_IN_LOCAL_ENV_OR_CONFIG__\\\\"
        },
        {
          "description": "Redact maintainer Unix home path",
          "pattern": "/home/[^/\"\\s]+/",
          "replacement": "__SET_IN_LOCAL_ENV_OR_CONFIG__/"
        },
        {
          "description": "Redact private proxy hostname",
          "pattern": "https?://ai\\.privatemail\\.site",
          "replacement": "https://your-proxy.example.com"
        },
        {
          "description": "Redact private IPv4 provider endpoints",
          "pattern": "https?://(?:(?:10|127)(?:\\.[0-9]{1,3}){3}|192\\.168(?:\\.[0-9]{1,3}){2}|172\\.(?:1[6-9]|2[0-9]|3[0-1])(?:\\.[0-9]{1,3}){2}|100\\.(?:6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])(?:\\.[0-9]{1,3}){2})(?::[0-9]+)?(?:/[^\"\\s]*)?",
          "replacement": "https://your-proxy.example.com/v1"
        }
      ]
    }
  ],
  "exclude": [
    ".env",
    "opencode.json",
    "opencode.tmp.json",
    "memory.db",
    "memory.db-shm",
    "memory.db-wal",
    "node_modules",
    "*.bak",
    "*.backup",
    "*.tmp",
    "*.temp",
    "*.log",
    "*.orig",
    "*.old"
  ],
  "secretPatterns": [
    "(?i)(api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|secret|password)\\s*[:=]\\s*['\"]?[A-Za-z0-9_./+=:-]{16,}",
    "sk-[A-Za-z0-9]{20,}",
    "https?://100\\.(?:6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])(?:\\.[0-9]{1,3}){2}(?::[0-9]+)?(?:/[^\"\\s]*)?",
    "ghp_[A-Za-z0-9_]{20,}",
    "github_pat_[A-Za-z0-9_]{20,}",
    "xox[baprs]-[A-Za-z0-9-]{20,}",
    "AKIA[0-9A-Z]{16}"
  ]
}
